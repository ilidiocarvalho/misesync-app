        <div class="content-card">
            <h2 class="font-serif text-4xl md:text-6xl mb-12 text-center">Soluções <span class="text-primary italic">Sob Medida</span></h2>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-cardBg p-8 rounded-xl border border-white/5">
                    <i class="fa-solid fa-boxes-stacked text-primary text-3xl mb-6"></i>
                    <h3 class="text-xl font-bold mb-4">Kits & Produção</h3>
                    <p class="text-sm text-muted">Consolidação automática de pedidos semanais em fichas de produção e listas de compras únicas.</p>
                </div>
                <div class="bg-cardBg p-8 rounded-xl border border-white/5">
                    <i class="fa-solid fa-store text-primary text-3xl mb-6"></i>
                    <h3 class="text-xl font-bold mb-4">Festivais (POS)</h3>
                    <p class="text-sm text-muted">Interface mobile para venda rápida. Registo de MBWay e Dinheiro em dois toques com fecho de caixa.</p>
                </div>
                <div class="bg-cardBg p-8 rounded-xl border border-white/5">
                    <i class="fa-solid fa-calendar-check text-primary text-3xl mb-6"></i>
                    <h3 class="text-xl font-bold mb-4">Agenda Híbrida</h3>
                    <p class="text-sm text-muted">Calendário centralizado para eventos privados, datas de produção e banca de rua.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 5: A PROPOSTA -->
    <section>
        <div class="content-card text-center">
            <h2 class="font-serif text-4xl md:text-6xl mb-16">Estatuto <span class="text-primary italic">Laboratório Beta</span></h2>
            <div class="grid md:grid-cols-3 gap-6">
                <div class="bg-cardBg/50 p-8 rounded-2xl border border-white/5">
                    <i class="fa-solid fa-shield-halved text-primary text-4xl mb-6"></i>
                    <h4 class="text-xl font-bold mb-2">Setup Zero</h4>
                    <p class="text-muted text-sm leading-relaxed">Assumo 100% do custo técnico de desenvolvimento e infraestrutura Cloud.</p>
                </div>
                <div class="bg-cardBg/50 p-8 rounded-2xl border border-blue-500/30">
                    <i class="fa-solid fa-comments text-blue-500 text-4xl mb-6"></i>
                    <h4 class="text-xl font-bold mb-2 text-blue-500">Design Partners</h4>
                    <p class="text-muted text-sm leading-relaxed">O teu único "trabalho" é usar a app e dizer o que precisa de ser melhorado.</p>
                </div>
                <div class="bg-cardBg/50 p-8 rounded-2xl border border-primary/30">
                    <i class="fa-solid fa-box-open text-primary text-4xl mb-6"></i>
                    <h4 class="text-xl font-bold mb-2 uppercase">Permuta</h4>
                    <p class="text-muted text-sm leading-relaxed font-semibold text-primary">Acesso Vitalício Gratuito</p>
                    <p class="text-muted text-xs mt-2 italic text-white/60">Em troca de uns belos kits de refeição ocasionalmente!</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 6: ROADMAP -->
